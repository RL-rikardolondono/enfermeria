{
  "name": "enfermeria-api",
  "version": "1.0.0",
  "description": "API REST - Plataforma Enfermeria Domiciliaria Reina Elizabeth IPS",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "npm install --legacy-peer-deps && prisma generate && tsc",
    "start": "node dist/server.js",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "ts-node src/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/websocket": "^8.3.1",
    "@prisma/client": "^5.13.0",
    "bcryptjs": "^2.4.3",
    "fastify": "^4.27.0",
    "ioredis": "^5.3.2",
    "zod": "^3.23.8",
    "uuid": "^9.0.1",
    "pino": "^9.1.0",
    "pino-pretty": "^11.0.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.13.0",
    "@types/uuid": "^9.0.8",
    "@types/web-push": "^3.3.3",
    "prisma": "^5.13.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
